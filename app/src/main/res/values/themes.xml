<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HelloWorld" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryContainer">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryContainer">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/purple_700</item>
    </style>
    <style name="ManeuverTextAppearance" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColorHighlight">#000000</item>
        <item name="android:textColorHint">#000000</item>
    </style>
    <style name="MapboxCustomManeuverTurnIconStyle" parent="MapboxStyleTurnIconManeuver">
        <item name="maneuverTurnIconColor">#000000</item>
        <item name="android:tint">#000000</item>
        <item name="maneuverTurnIconShadowColor">#808080</item>
    </style>
    <style name="ManeuverTextAppearance.Overlay" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColorHighlight">#FFFFFF</item>
        <item name="android:textColorHint">#FFFFFF</item>
    </style>

    <style name="MapboxCustomManeuverTurnIconStyle.Overlay" parent="MapboxStyleTurnIconManeuver">
        <item name="maneuverTurnIconColor">#FFFFFF</item>
        <item name="maneuverTurnIconShadowColor">#00000000</item>
    </style>

    <style name="LaneGuidanceTurnIconStyle" parent="MapboxStyleTurnIconManeuver">
        <item name="maneuverTurnIconColor">#FFFFFF</item>
        <item name="maneuverTurnIconShadowColor">#808080</item>
    </style>

    <style name="MapboxCustomManeuverStyle.Overlay" parent="MapboxStyleManeuverView">
        <item name="maneuverViewBackgroundColor">@android:color/transparent</item>
        <item name="subManeuverViewBackgroundColor">@android:color/transparent</item>
        <item name="upcomingManeuverViewBackgroundColor">@android:color/transparent</item>
        <item name="maneuverViewIconStyle">@style/MapboxCustomManeuverTurnIconStyle.Overlay</item>
        <item name="laneGuidanceManeuverIconStyle">@style/MapboxCustomManeuverTurnIconStyle.Overlay</item>
    </style>
</resources>
